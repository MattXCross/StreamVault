{
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "Catalogue": "Data Source=streamvault.db;Default Timeout=30"
  },
  "Analytics": {
    "EnableSimulator": true,
    "PlayEventRetentionDays": 30,
    "EventsPerSecond": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
