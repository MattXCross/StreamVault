@model ContentFormViewModel

<div class="mb-3">
    <label asp-for="Title" class="form-label"></label>
    <input asp-for="Title" class="form-control" />
    <span asp-validation-for="Title" class="text-danger"></span>
</div>
<div class="mb-3">
    <label asp-for="Description" class="form-label"></label>
    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>
<div class="row">
    <div class="col-md-4 mb-3">
        <label asp-for="ReleaseDate" class="form-label"></label>
        <input asp-for="ReleaseDate" class="form-control" />
        <span asp-validation-for="ReleaseDate" class="text-danger"></span>
    </div>
    <div class="col-md-4 mb-3">
        <label asp-for="AgeRating" class="form-label"></label>
        <select asp-for="AgeRating" asp-items="Html.GetEnumSelectList<AgeRating>()" class="form-select">
            <option value="">Select a rating</option>
        </select>
        <span asp-validation-for="AgeRating" class="text-danger"></span>
    </div>
    <div class="col-md-4 mb-3">
        <label asp-for="Genre" class="form-label"></label>
        <input asp-for="Genre" class="form-control" />
        <span asp-validation-for="Genre" class="text-danger"></span>
    </div>
</div>
