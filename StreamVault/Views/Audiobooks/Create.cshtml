@model AudiobookFormViewModel
@{
    ViewData["Title"] = "Add audiobook";
}

<h1>Add audiobook</h1>

<form asp-action="Create" class="col-md-8">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <partial name="_CommonContentFields" />
    <partial name="_AudiobookFields" />
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-controller="Catalogue" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
